<apex:page standardController="Case"
           extensions="DocusignCaseConfirmController"
           showHeader="false"
           sidebar="false"
           lightningStylesheets="true"
           docType="html-5.0">

    <style>
        body { font-family: Arial, sans-serif; background: #ffffff; }
        .container { padding: 18px; }
        .intro { margin-bottom: 16px; font-size: 14px; }
        .box {
            border: 1px solid #d8dde6; border-radius: 4px;
            padding: 14px; margin-bottom: 16px; background: #ffffff;
        }
        .row { margin-bottom: 12px; }
        .label {
            font-size: 11px; text-transform: uppercase; color: #54698d;
            font-weight: bold; margin-bottom: 3px;
        }
        .value { font-size: 14px; color: #080707; }
        .fileHint { font-size: 12px; color: #54698d; margin-bottom: 8px; }
        .fileTable { width: 100%; border-collapse: collapse; }
        .fileTable td {
            padding: 6px 8px; border-bottom: 1px solid #f0f0f0;
            font-size: 13px; color: #080707; vertical-align: middle;
        }
        .fileTable tr:last-child td { border-bottom: none; }
        .fileCheck { width: 28px; text-align: center; }
        .fileName { font-weight: bold; }
        .fileMeta { color: #54698d; white-space: nowrap; text-align: right; }
        .warning {
            border: 1px solid #ffb75d; background: #fff3e0;
            padding: 12px; border-radius: 4px; margin-bottom: 16px;
        }
        .success {
            border: 1px solid #45c65a; background: #e6f9ea;
            padding: 12px; border-radius: 4px; margin-bottom: 16px;
        }
        .footer {
            border-top: 1px solid #d8dde6; padding-top: 14px; text-align: right;
        }
        .primaryButton {
            background: #0176d3; color: #ffffff; border: 1px solid #0176d3;
            border-radius: 4px; padding: 8px 14px; font-weight: bold; cursor: pointer;
        }
        .primaryButton[disabled] {
            background: #c9c9c9; border-color: #c9c9c9; cursor: not-allowed;
        }
        .secondaryButton {
            background: #ffffff; color: #0176d3; border: 1px solid #d8dde6;
            border-radius: 4px; padding: 8px 14px; margin-right: 8px; cursor: pointer;
        }
        .sendingNote { color: #54698d; font-size: 12px; margin-right: 12px; }
        ul { margin-top: 8px; margin-bottom: 0; }
    </style>

    <script>
        function goBackToCase() {
            window.top.location.href = '/' + '{!caseId}';
        }
    </script>

    <apex:form id="form">
        <div class="container">

            <apex:pageMessages id="messages" />

            <apex:outputPanel id="main">

                <apex:outputPanel rendered="{!sent}">
                    <div class="success">
                        <strong>Verzonden.</strong><br/>
                        {!successMessage}
                    </div>
                </apex:outputPanel>

                <apex:outputPanel rendered="{!NOT(sent)}">

                    <div class="intro">
                        Controleer onderstaande gegevens en selecteer de bestanden voordat de envelope naar DocuSign wordt verzonden.
                    </div>

                    <div class="box">
                        <div class="row">
                            <div class="label">Case</div>
                            <div class="value">Case {!caseNumber}</div>
                        </div>
                        <div class="row">
                            <div class="label">Account</div>
                            <div class="value">{!accountLabel}</div>
                        </div>
                        <div class="row">
                            <div class="label">Contact</div>
                            <div class="value">{!contactLabel}</div>
                        </div>
                        <div class="row">
                            <div class="label">Ter controle van</div>
                            <div class="value">{!controleurLabel}</div>
                        </div>
                    </div>

                    <div class="box">
                        <div class="row">
                            <div class="label">Bestanden ({!fileCount})</div>

                            <apex:outputPanel rendered="{!hasFiles}">
                                <div class="fileHint">
                                    Vink aan welke bestanden meegestuurd moeten worden in de envelope.
                                    Alle door DocuSign ondersteunde formaten zijn toegestaan (Word, Excel, PowerPoint, PDF, afbeeldingen, tekst).
                                    Selecteer minimaal één PDF — de handtekening-anchors staan alleen in de PDF.
                                </div>
                                <table class="fileTable">
                                    <apex:repeat value="{!files}" var="fileOption">
                                        <tr>
                                            <td class="fileCheck">
                                                <apex:inputCheckbox value="{!fileOption.selected}" />
                                            </td>
                                            <td class="fileName">{!fileOption.label}</td>
                                            <td class="fileMeta">{!fileOption.sizeLabel}</td>
                                            <td class="fileMeta">{!fileOption.createdDateLabel}</td>
                                        </tr>
                                    </apex:repeat>
                                </table>
                            </apex:outputPanel>

                            <apex:outputPanel rendered="{!NOT(hasFiles)}">
                                <div class="value">Geen geschikte bestanden gevonden op deze Case.</div>
                            </apex:outputPanel>
                        </div>
                    </div>

                    <apex:outputPanel rendered="{!hasErrors}">
                        <div class="warning">
                            <strong>Versturen is nog niet mogelijk.</strong>
                            <ul>
                                <apex:repeat value="{!errors}" var="errorText">
                                    <li>{!errorText}</li>
                                </apex:repeat>
                            </ul>
                        </div>
                    </apex:outputPanel>

                </apex:outputPanel>

                <div class="footer">

                    <!-- Disable de knop zodra het request start (double-submit guard). -->
                    <apex:actionStatus id="sendStatus"
                        onstart="var b=document.getElementById('{!$Component.form.sendBtn}'); if(b){b.disabled=true;}"
                        onstop="">
                        <apex:facet name="start">
                            <span class="sendingNote">Bezig met verzenden...</span>
                        </apex:facet>
                    </apex:actionStatus>

                    <input type="button"
                           value="Terug naar Case"
                           class="secondaryButton"
                           onclick="goBackToCase();" />

                    <apex:commandButton id="sendBtn"
                                        value="Versturen via DocuSign"
                                        action="{!sendEnvelope}"
                                        rerender="form"
                                        status="sendStatus"
                                        disabled="{!disableSend}"
                                        styleClass="primaryButton" />
                </div>

            </apex:outputPanel>
        </div>
    </apex:form>
</apex:page>
